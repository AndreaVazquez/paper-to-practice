# ─── Django ──────────────────────────────────────────────────────────────────
DEBUG=True
SECRET_KEY=secret
DATABASE_URL=sqlite:///db.sqlite3

# Superuser --no-input

DJANGO_SUPERUSER_USERNAME=
DJANGO_SUPERUSER_EMAIL=
DJANGO_SUPERUSER_PASSWORD=


# ─── TEXT role (metadata extraction, keyword generation, Annotate Drift old) ─────────────────────
TEXT_PROVIDER=groq
TEXT_MODEL=openai/gpt-oss-120b
#TEXT_MODEL=moonshotai/kimi-k2-instruct-0905
#TEXT_MODEL=moonshotai/kimi-k2-instruct
#TEXT_MODEL=openai/gpt-oss-20b
#TEXT_MODEL=llama-3.3-70b-versatile
#TEXT_MODEL=qwen/qwen3-32b
TEXT_API_KEY=
TEXT_RPM=1000
TEXT_RPD=7000
TEXT_CONCURRENCY=6

# ─── IMAGE role (figure classification) ──────────────────────────────────────
IMAGE_PROVIDER=groq
# IMAGE_MODEL=meta-llama/llama-4-maverick-17b-128e-instruct
IMAGE_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
IMAGE_API_KEY=
IMAGE_FALLBACK_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
IMAGE_RPM=1000
IMAGE_RPD=7000
IMAGE_CONCURRENCY=6


# ── DETECT_CHARTS role ────────────────────────────────────────────────────────
# Used by: detect_chart_types (Stage A+ — LLM code analysis)
# Triggers only when pattern matching (Stage A) finds nothing.
# Text-only role: kimi-k2 reads notebook code and identifies chart types.
# No vision needed here — image classification falls back to IMAGE role.
DETECT_CHARTS_PROVIDER=groq
DETECT_CHARTS_MODEL=moonshotai/kimi-k2-instruct-0905
DETECT_CHARTS_API_KEY=
DETECT_CHARTS_RPM=5
DETECT_CHARTS_RPD=1000
DETECT_CHARTS_CONCURRENCY=3



# ─── REASONING role (narrative generation) ───────────────────────────────────
REASONING_PROVIDER=gemini
REASONING_MODEL=gemini-3-flash-preview
REASONING_API_KEY_1=
REASONING_API_KEY_2=
REASONING_FALLBACK_PROVIDER=groq
REASONING_FALLBACK_MODEL=moonshotai/kimi-k2-instruct-0905
REASONING_FALLBACK_API_KEY=
REASONING_RPM=5
REASONING_RPD=40
REASONING_CONCURRENCY=2

# With 40 should never fallback increase to use kimi k2


# ─── TRACE_ANNOTATE role (multimodal drift annotation + figure verification) ──
# Uses Gemini 3.1 Flash Lite — passes the actual figure image so the model
# can verify the classification before annotating drift.
# 500 RPD quota is per model, independent of REASONING's quota.
TRACE_ANNOTATE_PROVIDER=gemini
TRACE_ANNOTATE_MODEL=gemini-3-flash-preview
#TRACE_ANNOTATE_MODEL=gemini-3.1-flash-lite-preview
TRACE_ANNOTATE_API_KEY_1=
TRACE_ANNOTATE_API_KEY_2=
TRACE_ANNOTATE_RPM=20
TRACE_ANNOTATE_RPD=1000
TRACE_ANNOTATE_CONCURRENCY=18


# ─── QUERY role (NL → structured DB query) ───────────────────────────────────
QUERY_PROVIDER=groq
QUERY_MODEL=openai/gpt-oss-120b
# QUERY_MODEL=moonshotai/kimi-k2-instruct-0905
QUERY_API_KEY=
QUERY_RPM=30
QUERY_RPD=1000
QUERY_CONCURRENCY=1

# ─── Kaggle (repository crawl) ───────────────────────────────────────────────
KAGGLE_USERNAME=
KAGGLE_KEY=


# ─── GitHub (for crawl_repos --platform github) ───────────────────────────────
# Permissions needed: public repositories (read-only) is enough
GITHUB_TOKEN=
